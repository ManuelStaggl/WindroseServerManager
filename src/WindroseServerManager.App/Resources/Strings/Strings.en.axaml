    <sys:String x:Key="About.ThirdPartyLicenses.Heading">Third-Party Licenses</sys:String>
    <sys:String x:Key="About.ThirdPartyLicenses.WindrosePlus.Intro">WindrosePlus (MIT License) — © HumanGenome. Bundles UE4SS and the WindrosePlus server mod.</sys:String>
