<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WindroseServerManager.App.Views.Dialogs.LinkNexusDialog"
        Width="480"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BrandNavySurfaceBrush}"
        Title="{DynamicResource Dialog.LinkNexus.Title}">
    <Border CornerRadius="8"
            Background="{DynamicResource BrandNavySurfaceBrush}"
            BorderBrush="{DynamicResource BrandNavyBorderBrush}"
            BorderThickness="1"
            Padding="20">
        <StackPanel Spacing="14">
            <TextBlock Classes="section-header" Text="{DynamicResource Dialog.LinkNexus.Title}" />
            <TextBlock Classes="body" TextWrapping="Wrap"
                       Text="{DynamicResource Dialog.LinkNexus.Body}" />
            <TextBlock x:Name="ModNameLabel" Classes="caption" FontWeight="SemiBold" TextWrapping="Wrap" />

            <StackPanel Spacing="4">
                <TextBlock Classes="caption" Text="{DynamicResource Dialog.LinkNexus.UrlLabel}" />
                <TextBox x:Name="UrlInput" Watermark="https://www.nexusmods.com/windrose/mods/…"
                         KeyDown="OnUrlKeyDown" />
            </StackPanel>

            <Border x:Name="ErrorPanel" IsVisible="False"
                    Padding="12,10" CornerRadius="6"
                    Background="{DynamicResource BrandErrorBrush}">
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap"
                           Foreground="#FFFFFF" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                <Button Content="{DynamicResource Action.Cancel}" Click="OnCancelClick" />
                <Button x:Name="ConfirmButton" Classes="primary"
                        Content="{DynamicResource Dialog.LinkNexus.Confirm}"
                        Click="OnConfirmClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
