<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WindroseServerManager.App.Views.Dialogs.ConfirmDialog"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BrandNavySurfaceBrush}"
        Title="{DynamicResource Dialog.Confirm.Title}">
    <Border CornerRadius="8"
            Background="{DynamicResource BrandNavySurfaceBrush}"
            BorderBrush="{DynamicResource BrandNavyBorderBrush}"
            BorderThickness="1"
            Padding="20">
        <StackPanel Spacing="16">
            <TextBlock x:Name="TitleText" Classes="section-header" TextWrapping="Wrap" />
            <TextBlock x:Name="MessageText" Classes="body" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
                <Button x:Name="CancelButton" Content="{DynamicResource Action.Cancel}" Click="OnCancelClick" />
                <Button x:Name="ConfirmButton" Classes="primary" Content="{DynamicResource Action.Confirm}" Click="OnConfirmClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
