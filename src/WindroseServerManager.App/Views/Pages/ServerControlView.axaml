<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             xmlns:svc="using:WindroseServerManager.App.Services"
             x:Class="WindroseServerManager.App.Views.Pages.ServerControlView"
             x:DataType="vm:ServerControlViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveRestartScheduleCommand}" />
    </UserControl.KeyBindings>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="0">
        <TextBlock Classes="page-title" Text="{DynamicResource ServerControl.Title}" />
        <TextBlock Classes="caption muted" Text="{DynamicResource ServerControl.Subtitle}" Margin="0,4,0,20" />

        <Border Classes="card" Margin="0,0,0,16">
            <StackPanel Spacing="16">
                <TextBlock Classes="section-header" Text="{DynamicResource ServerControl.ScheduledRestarts}" />
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <CheckBox Content="{DynamicResource ServerControl.Enabled}" IsChecked="{Binding ScheduledRestartEnabled}" VerticalAlignment="Center" />
                    <TextBlock Classes="body" Text="{DynamicResource ServerControl.At}" VerticalAlignment="Center" />
                    <TimePicker SelectedTime="{Binding DailyRestartTimeSpan}" MinuteIncrement="15" />
                    <TextBlock Classes="body" Text="{DynamicResource ServerControl.ClockWarn}" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding RestartWarnMinutes}" Minimum="0" Maximum="60" FormatString="0" Width="110" />
                    <TextBlock Classes="body" Text="{DynamicResource ServerControl.MinBefore}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Spacing="6">
                    <TextBlock Classes="caption" Text="{DynamicResource ServerControl.Weekdays}" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Mon}" IsChecked="{Binding RestartMon}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Tue}" IsChecked="{Binding RestartTue}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Wed}" IsChecked="{Binding RestartWed}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Thu}" IsChecked="{Binding RestartThu}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Fri}" IsChecked="{Binding RestartFri}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Sat}" IsChecked="{Binding RestartSat}" />
                        <ToggleButton Classes="weekday-pill" Content="{DynamicResource Weekday.Sun}" IsChecked="{Binding RestartSun}" />
                    </StackPanel>
                </StackPanel>

                <Border Classes="divider" />

                <TextBlock Classes="section-header" Text="{DynamicResource ServerControl.AutoThresholds}" />
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <CheckBox Content="{DynamicResource ServerControl.RamOver}" IsChecked="{Binding AutoRestartOnHighRamEnabled}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding AutoRestartRamThresholdPercent}" Minimum="10" Maximum="100" FormatString="0" Width="110"
                                       IsEnabled="{Binding AutoRestartOnHighRamEnabled}" />
                        <TextBlock Classes="body" Text="{DynamicResource ServerControl.RamOverSuffix}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <CheckBox Content="{DynamicResource ServerControl.UptimeOver}" IsChecked="{Binding AutoRestartOnMaxUptimeEnabled}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding AutoRestartMaxUptimeHours}" Minimum="1" Maximum="168" FormatString="0" Width="110"
                                       IsEnabled="{Binding AutoRestartOnMaxUptimeEnabled}" />
                        <TextBlock Classes="body" Text="{DynamicResource ServerControl.Hours}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <Border Classes="divider" />

                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox Content="{DynamicResource ServerControl.BackupOnRestart}" IsChecked="{Binding BackupOnRestartEnabled}" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Classes="primary" Content="{DynamicResource Action.Save}" Command="{Binding SaveRestartScheduleCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Classes="card" Margin="0,0,0,16">
            <Grid RowDefinitions="Auto,*" MaxHeight="260">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <TextBlock Classes="section-header" Text="{DynamicResource ServerControl.SessionHistory}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="subtle"
                            Command="{Binding ClearSessionHistoryCommand}"
                            ToolTip.Tip="{DynamicResource ServerControl.ClearHistory.Tip}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="14" />
                            <TextBlock Text="{DynamicResource ServerControl.Clear}" />
                        </StackPanel>
                    </Button>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,8">
                                    <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                                            Background="{Binding Type, Converter={x:Static vm:ServerEventTypeToBrushConverter.Instance}}"
                                            VerticalAlignment="Top" Margin="0,2,10,0">
                                        <TextBlock Text="{Binding Type, Converter={x:Static vm:ServerEventTypeToIconConverter.Instance}}"
                                                   Foreground="White" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Classes="body" FontWeight="SemiBold"
                                                   Text="{Binding ., Converter={x:Static vm:ServerEventToTitleConverter.Instance}}" />
                                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                                   Text="{Binding ., Converter={x:Static vm:ServerEventToDetailConverter.Instance}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Grid.Row="1" Text="{DynamicResource ServerControl.NoEventsYet}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrandTextMutedBrush}"
                           IsVisible="{Binding Events.Count, Converter={x:Static vm:CountToInverseBoolConverter.Instance}}" />
            </Grid>
        </Border>

        <Border Classes="card" MinHeight="420">
            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <TextBlock Grid.Column="0" Classes="section-header" Text="{DynamicResource ServerControl.LiveLog}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Classes="caption" Text="{DynamicResource ServerControl.Buffer}" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding LogBufferSizeOptions}" SelectedItem="{Binding LogBufferSize}" Width="90" />
                        <Button Classes="subtle" Content="{DynamicResource ServerControl.LogFolder}" Command="{Binding OpenLogFolderCommand}" />
                        <Button Classes="subtle" Content="{DynamicResource ServerControl.Export}" Command="{Binding ExportLogCommand}" />
                        <Button Classes="subtle" Content="{DynamicResource ServerControl.Clear}" Command="{Binding ClearLogCommand}" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBox Grid.Column="0" Text="{Binding SearchQuery}"
                             PlaceholderText="{DynamicResource ServerControl.SearchLog}" />
                    <TextBlock Grid.Column="1" Classes="caption" VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="{Binding FilteredLinesDisplay}" />
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                    <RadioButton GroupName="LogFilter" Content="{DynamicResource ServerControl.Filter.All}" IsChecked="{Binding IsAllFilter}" />
                    <RadioButton GroupName="LogFilter" Content="{DynamicResource ServerControl.Filter.InfoPlus}" IsChecked="{Binding IsInfoPlusFilter}" />
                    <RadioButton GroupName="LogFilter" Content="{DynamicResource ServerControl.Filter.WarningPlus}" IsChecked="{Binding IsWarningPlusFilter}" />
                    <RadioButton GroupName="LogFilter" Content="{DynamicResource ServerControl.Filter.ErrorOnly}" IsChecked="{Binding IsErrorOnlyFilter}" />
                </StackPanel>
                <ScrollViewer Grid.Row="3" svc:AutoScrollBehavior.IsEnabled="True">
                    <ItemsControl ItemsSource="{Binding FilteredLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="log-line"
                                           Text="{Binding}"
                                           Foreground="{Binding ., Converter={x:Static vm:LogLineToBrushConverter.Instance}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </StackPanel>
    </ScrollViewer>
</UserControl>
