<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.SeaChartView"
             x:DataType="vm:SeaChartViewModel">
    <Panel>

        <!-- Opt-out empty state -->
        <StackPanel Classes="empty-state" IsVisible="{Binding !IsWindrosePlusActive}">
            <TextBlock Classes="empty-state-icon" Text="&#xE774;" />
            <TextBlock Classes="empty-state-title"
                       Text="{DynamicResource SeaChart.OptOut.Title}" />
            <TextBlock Classes="empty-state-body"
                       Text="{DynamicResource SeaChart.OptOut.Desc}" />
            <Button Classes="primary"
                    Content="{DynamicResource WindrosePlus.OptOut.Cta}"
                    Command="{Binding InstallWindrosePlusCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0" />
        </StackPanel>

        <!-- Normal content -->
        <Grid IsVisible="{Binding IsWindrosePlusActive}"
              RowDefinitions="Auto,*" RowSpacing="12">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <TextBlock Text="{DynamicResource SeaChart.Title}" Classes="page-title"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Classes="subtle"
                            Content="{DynamicResource SeaChart.OpenLivemap}"
                            Command="{Binding OpenLivemapCommand}" />
                    <Button Classes="subtle"
                            Content="{DynamicResource SeaChart.Refresh}"
                            Command="{Binding ReloadCommand}" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Classes="card" Padding="0" ClipToBounds="True">
                <Grid>
                    <NativeWebView x:Name="LiveMapWebView"
                                   Source="{Binding LivemapUrl}"
                                   IsVisible="{Binding HasLivemap}" />
                    <!-- Empty state when dashboard is not running -->
                    <StackPanel Classes="empty-state" IsVisible="{Binding !HasLivemap}">
                        <TextBlock Classes="empty-state-icon" Text="&#xE774;" />
                        <TextBlock Classes="empty-state-title"
                                   Text="{DynamicResource SeaChart.NoMap}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid><!-- /Normal content -->

    </Panel>
</UserControl>
