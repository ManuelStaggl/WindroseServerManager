<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             xmlns:models="using:WindroseServerManager.Core.Models"
             x:Class="WindroseServerManager.App.Views.Pages.ConfigurationView"
             x:DataType="vm:ConfigurationViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveServerCommand}" />
    </UserControl.KeyBindings>
    <ScrollViewer>
        <StackPanel Margin="0,0,0,24">
            <TextBlock Classes="page-title" Text="{DynamicResource Configuration.Title}" />
            <TextBlock Classes="caption" Text="{DynamicResource Configuration.Subtitle}" Margin="0,4,0,20" />

            <Border Classes="card" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="!" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource BrandWarningBrush}" VerticalAlignment="Center" />
                    <TextBlock Classes="body" TextWrapping="Wrap"
                               Text="{DynamicResource Configuration.StopHint}" />
                </StackPanel>
            </Border>

            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Configuration.Server}" />

                    <StackPanel Spacing="4" DataContext="{Binding Server}">
                        <TextBlock Classes="caption" Text="{DynamicResource Configuration.ServerName}" />
                        <TextBox Text="{Binding ServerName}"
                                 ToolTip.Tip="{DynamicResource Configuration.ServerName.Tip}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Classes="caption" Text="{DynamicResource Configuration.InviteCode}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Grid.Column="0" Text="{Binding InviteCode}" FontFamily="Consolas,Courier New"
                                     ToolTip.Tip="{DynamicResource Configuration.InviteCode.Tip}" />
                            <Button Grid.Column="1" Classes="subtle" Content="{DynamicResource Configuration.InviteCode.Reroll}"
                                    Command="{Binding GenerateInviteCodeCommand}"
                                    ToolTip.Tip="{DynamicResource Configuration.InviteCode.RerollTip}" />
                        </Grid>
                        <TextBlock Classes="caption"
                                   Text="{DynamicResource Configuration.InviteCode.Hint}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Foreground="{DynamicResource BrandErrorBrush}"
                                   Text="{Binding InviteCodeError}"
                                   IsVisible="{Binding InviteCodeError, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" DataContext="{Binding Server}">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0">
                            <TextBlock Classes="caption" Text="{DynamicResource Configuration.MaxPlayers}" />
                            <NumericUpDown Value="{Binding MaxPlayerCount}" Minimum="1" Maximum="10" Increment="1"
                                           ToolTip.Tip="{DynamicResource Configuration.MaxPlayers.Tip}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                            <TextBlock Classes="caption" Text="{DynamicResource Configuration.P2pProxy}" />
                            <TextBox Text="{Binding P2pProxyAddress}" Watermark="127.0.0.1"
                                     ToolTip.Tip="{DynamicResource Configuration.P2pProxy.Tip}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="4" DataContext="{Binding Server}">
                        <CheckBox Content="{DynamicResource Configuration.PasswordProtected}" IsChecked="{Binding IsPasswordProtected}"
                                  ToolTip.Tip="{DynamicResource Configuration.PasswordProtected.Tip}" />
                        <TextBox Text="{Binding Password}" PasswordChar="•" IsEnabled="{Binding IsPasswordProtected}" />
                    </StackPanel>

                    <StackPanel Spacing="2"
                                IsVisible="{Binding PersistentServerId, Converter={x:Static ObjectConverters.IsNotNull}}"
                                ToolTip.Tip="{DynamicResource Configuration.PersistentServerId.Tip}">
                        <TextBlock Classes="caption" Text="{DynamicResource Configuration.PersistentServerId}" />
                        <SelectableTextBlock
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontSize="12"
                                   Foreground="{DynamicResource BrandTextPrimaryBrush}"
                                   Text="{Binding PersistentServerId}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Foreground="{DynamicResource BrandTextMutedBrush}"
                                   Text="{DynamicResource Configuration.PersistentServerId.Hint}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Classes="primary" Content="{DynamicResource Configuration.SaveServer}"
                                Command="{Binding SaveServerCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-header" Text="{DynamicResource Configuration.Actions}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="subtle" Content="{DynamicResource Configuration.OpenInstallDir}"
                                Command="{Binding OpenInstallDirCommand}"
                                IsEnabled="{Binding CanOpenInstallDir}" />
                        <Button Classes="subtle" Content="{DynamicResource Configuration.OpenServerDescription}"
                                Command="{Binding OpenServerDescriptionCommand}"
                                IsEnabled="{Binding CanOpenServerDescription}" />
                        <Button Classes="subtle" Content="{DynamicResource Configuration.OpenWorldsRoot}"
                                Command="{Binding OpenWorldsRootCommand}"
                                IsEnabled="{Binding CanOpenWorldsRoot}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Configuration.World}" />

                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Classes="body" Text="{DynamicResource Configuration.WorldSelection}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding WorldIds}"
                                  SelectedItem="{Binding SelectedWorldId}" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2" Content="{DynamicResource Configuration.Activate}" Command="{Binding ActivateWorldCommand}"
                                IsEnabled="{Binding SelectedWorldId, Converter={x:Static ObjectConverters.IsNotNull}}" />
                        <Button Grid.Column="3" Content="{DynamicResource Configuration.NewWorld}" Command="{Binding CreateWorldCommand}" />
                        <Button Grid.Column="4" Classes="danger" Content="{DynamicResource Action.Delete}"
                                Command="{Binding DeleteWorldCommand}"
                                IsEnabled="{Binding SelectedWorldId, Converter={x:Static ObjectConverters.IsNotNull}}" />
                    </Grid>

                    <StackPanel Spacing="10"
                                IsVisible="{Binding World, Converter={x:Static ObjectConverters.IsNotNull}}">

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.WorldName}" />
                                <TextBox Text="{Binding WorldName}"
                                         ToolTip.Tip="{DynamicResource Configuration.WorldName.Tip}" />
                                <TextBlock Classes="caption" Foreground="{DynamicResource BrandErrorBrush}"
                                           Text="{Binding WorldNameError}"
                                           IsVisible="{Binding WorldNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.IslandId}" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <SelectableTextBlock Grid.Column="0"
                                               FontFamily="Consolas, Courier New, monospace"
                                               FontSize="12"
                                               Foreground="{DynamicResource BrandTextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center"
                                               Text="{Binding SelectedWorldId}" />
                                    <Button Grid.Column="1" Classes="subtle" Content="{DynamicResource Action.Copy}"
                                            Command="{Binding CopyIslandIdCommand}"
                                            ToolTip.Tip="{DynamicResource Configuration.CopyIslandIdTip}" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.Preset}" />
                                <ComboBox ItemsSource="{Binding PresetOptions}"
                                          SelectedItem="{Binding WorldPresetType}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip.Tip="{DynamicResource Configuration.Preset.Tip}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ., Converter={x:Static vm:WorldPresetTypeToLocalizedTextConverter.Instance}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.CombatDifficulty}" />
                                <ComboBox ItemsSource="{Binding CombatOptions}"
                                          SelectedItem="{Binding CombatDifficulty}"
                                          HorizontalAlignment="Stretch"
                                          ToolTip.Tip="{DynamicResource Configuration.CombatDifficulty.Tip}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ., Converter={x:Static vm:CombatDifficultyToLocalizedTextConverter.Instance}}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Classes="section-header" Text="{DynamicResource Configuration.Parameters}" Margin="0,12,0,0" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="24" RowSpacing="12">

                            <StackPanel Grid.Column="0" Grid.Row="0" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.MobHealth}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.2" Maximum="5.0" TickFrequency="0.1"
                                            Value="{Binding MobHealth}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.2" Maximum="5.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding MobHealth}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="0" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.MobDamage}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.2" Maximum="5.0" TickFrequency="0.1"
                                            Value="{Binding MobDamage}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.2" Maximum="5.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding MobDamage}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="1" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.ShipsHealth}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.4" Maximum="5.0" TickFrequency="0.1"
                                            Value="{Binding ShipsHealth}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.4" Maximum="5.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding ShipsHealth}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.ShipsDamage}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.2" Maximum="2.5" TickFrequency="0.1"
                                            Value="{Binding ShipsDamage}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.2" Maximum="2.5" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding ShipsDamage}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="2" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.BoardingDifficulty}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.2" Maximum="5.0" TickFrequency="0.1"
                                            Value="{Binding BoardingDifficulty}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.2" Maximum="5.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding BoardingDifficulty}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="2" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.CoopMobScaling}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.0" Maximum="2.0" TickFrequency="0.1"
                                            Value="{Binding CoopStatsCorrection}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.0" Maximum="2.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding CoopStatsCorrection}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="0" Grid.Row="3" Spacing="4">
                                <TextBlock Classes="caption" Text="{DynamicResource Configuration.CoopShipScaling}" />
                                <Grid ColumnDefinitions="*,90" ColumnSpacing="8">
                                    <Slider Grid.Column="0" Minimum="0.0" Maximum="2.0" TickFrequency="0.1"
                                            Value="{Binding CoopShipStatsCorrection}" />
                                    <NumericUpDown Grid.Column="1" Minimum="0.0" Maximum="2.0" Increment="0.1"
                                                   FormatString="0.00" Value="{Binding CoopShipStatsCorrection}" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <TextBlock Classes="section-header" Text="{DynamicResource Configuration.CoopExploration}" Margin="0,12,0,0" />
                        <StackPanel Spacing="8">
                            <CheckBox Content="{DynamicResource Configuration.CoopSharedQuests}" IsChecked="{Binding CoopSharedQuests}" />
                            <CheckBox Content="{DynamicResource Configuration.EasyExplore}" IsChecked="{Binding EasyExplore}" />
                        </StackPanel>

                        <Grid Margin="0,12,0,0" ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0" Classes="subtle" Content="{DynamicResource Configuration.OpenWorldDir}"
                                    Command="{Binding OpenSelectedWorldDirCommand}"
                                    IsEnabled="{Binding CanOpenSelectedWorldDir}" />
                            <Button Grid.Column="2" Classes="primary" Content="{DynamicResource Configuration.SaveWorld}"
                                    Command="{Binding SaveWorldCommand}" />
                        </Grid>
                    </StackPanel>

                    <TextBlock Classes="caption"
                               Text="{DynamicResource Configuration.NoWorldsHint}"
                               IsVisible="{Binding World, Converter={x:Static ObjectConverters.IsNull}}" />
                </StackPanel>
            </Border>

            <TextBlock Classes="caption" Margin="0,12,0,0" Text="{Binding StatusMessage}"
                       IsVisible="{Binding StatusMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
            <TextBlock Classes="caption" Foreground="{DynamicResource BrandErrorBrush}"
                       Text="{Binding ErrorMessage}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
