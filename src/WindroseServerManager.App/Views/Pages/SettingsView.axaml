<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
    </UserControl.KeyBindings>
    <ScrollViewer>
        <StackPanel Margin="24,0,24,24" Spacing="0">

            <!-- ═══ HEADER ═══ -->
            <TextBlock Classes="page-title" Text="{DynamicResource Settings.Title}" />
            <TextBlock Classes="caption" Text="{DynamicResource Settings.Subtitle}" Margin="0,4,0,0" />

            <!-- ═══════════════════════════════════════
                 GRUPPE: DARSTELLUNG
            ═══════════════════════════════════════ -->
            <TextBlock Classes="group-label" Text="{DynamicResource Settings.Group.Display}" />

            <Border Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="section-header" Text="{DynamicResource Settings.Language.Title}" />
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption}"
                              HorizontalAlignment="Left" MinWidth="240">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Classes="caption" TextWrapping="Wrap"
                               Text="{DynamicResource Settings.Language.Hint}" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════
                 GRUPPE: SERVER
            ═══════════════════════════════════════ -->
            <TextBlock Classes="group-label" Text="{DynamicResource Settings.Group.Server}" />

            <!-- Server-Start -->
            <Border Classes="card" Margin="0,0,0,12">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Settings.LaunchArgs.Title}" />

                    <CheckBox Content="{DynamicResource Settings.LaunchArgs.ConsoleLog}"
                              IsChecked="{Binding LogEnabled}" />

                    <CheckBox Content="{DynamicResource Settings.LaunchArgs.AutoRestartOnCrash}"
                              IsChecked="{Binding AutoRestartOnCrash}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Classes="caption" Text="{DynamicResource Settings.LaunchArgs.GracefulShutdown}" />
                            <NumericUpDown Value="{Binding GracefulShutdownSeconds}"
                                           Minimum="5" Maximum="600" FormatString="0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="caption" Text="{DynamicResource Settings.LaunchArgs.Extra}" />
                            <TextBox Text="{Binding ExtraLaunchArgs}"
                                     PlaceholderText="{DynamicResource Settings.LaunchArgs.Extra.Placeholder}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Classes="caption" TextWrapping="Wrap"
                               Text="{DynamicResource Settings.LaunchArgs.Hint}" />
                </StackPanel>
            </Border>

            <!-- Steam -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Settings.Steam.Title}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Classes="caption" Text="{DynamicResource Settings.Steam.AppId}" />
                            <TextBox Text="{Binding SteamAppId}" PlaceholderText="4129620" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="caption" Text="{DynamicResource Settings.Steam.Login}" />
                            <TextBox Text="{Binding SteamLogin}" PlaceholderText="anonymous" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Classes="caption" TextWrapping="Wrap"
                               Text="{DynamicResource Settings.Steam.Hint}" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════
                 GRUPPE: SYSTEM
            ═══════════════════════════════════════ -->
            <TextBlock Classes="group-label" Text="{DynamicResource Settings.Group.System}" />

            <!-- Netzwerk, Firewall & Autostart in einer Karte -->
            <Border Classes="card">
                <StackPanel Spacing="12">

                    <!-- Netzwerk-Info -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" Text="{DynamicResource Settings.Network.Title}" />
                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.Network.Hint}" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource BrandNavyBorderBrush}" Margin="0,2" />

                    <!-- Firewall -->
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-header" FontSize="14"
                                   Text="{DynamicResource Settings.Firewall.Title}" />
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Panel Width="10" Height="10">
                                <Ellipse Width="10" Height="10"
                                         Fill="{DynamicResource BrandSuccessBrush}"
                                         IsVisible="{Binding IsFirewallRuleInstalled}" />
                                <Ellipse Width="10" Height="10"
                                         Fill="{DynamicResource BrandTextMutedBrush}"
                                         IsVisible="{Binding !IsFirewallRuleInstalled}" />
                            </Panel>
                            <TextBlock Classes="body" Text="{DynamicResource Settings.Firewall.Installed}"
                                       IsVisible="{Binding IsFirewallRuleInstalled}" />
                            <TextBlock Classes="body" Text="{DynamicResource Settings.Firewall.NotInstalled}"
                                       IsVisible="{Binding !IsFirewallRuleInstalled}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Classes="primary" Content="{DynamicResource Settings.Firewall.Add}"
                                    Command="{Binding ToggleFirewallCommand}"
                                    IsVisible="{Binding !IsFirewallRuleInstalled}"
                                    IsEnabled="{Binding !IsFirewallBusy}" />
                            <Button Content="{DynamicResource Settings.Firewall.Remove}"
                                    Command="{Binding ToggleFirewallCommand}"
                                    IsVisible="{Binding IsFirewallRuleInstalled}"
                                    IsEnabled="{Binding !IsFirewallBusy}" />
                            <Button Content="{DynamicResource Settings.Firewall.Check}"
                                    Command="{Binding CheckFirewallCommand}"
                                    IsEnabled="{Binding !IsFirewallBusy}" />
                            <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                         VerticalAlignment="Center"
                                         IsVisible="{Binding IsFirewallBusy}" />
                        </StackPanel>
                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.Firewall.Hint}" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource BrandNavyBorderBrush}" Margin="0,2" />

                    <!-- Autostart -->
                    <StackPanel Spacing="6">
                        <TextBlock Classes="section-header" FontSize="14"
                                   Text="{DynamicResource Settings.AutoStart.Title}" />
                        <CheckBox Content="{DynamicResource Settings.AutoStart.Label}"
                                  IsChecked="{Binding AutoStartEnabled}" />
                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.AutoStart.Hint}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════
                 GRUPPE: WINDROSE PLUS
            ═══════════════════════════════════════ -->
            <TextBlock Classes="group-label" Text="{DynamicResource Settings.Group.WindrosePlus}" />

            <Border Classes="card">
                <StackPanel Spacing="12">

                    <!-- Status + Verwaltung -->
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-header" Text="{DynamicResource Settings.WindrosePlus.Title}" />
                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.WindrosePlus.Hint}" />
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Classes="caption" VerticalAlignment="Center"
                                       Text="{DynamicResource Settings.WindrosePlus.StatusLabel}" />
                            <TextBlock Classes="caption" VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrandAmberBrush}"
                                       FontWeight="SemiBold"
                                       Text="{Binding WindrosePlusStatusText}" />
                        </StackPanel>
                        <Button Content="{DynamicResource Settings.WindrosePlus.ManageButton}"
                                Command="{Binding OpenWindrosePlusDialogCommand}"
                                IsEnabled="{Binding HasServerConfigured}" />
                    </StackPanel>

                    <Rectangle Height="1" Fill="{DynamicResource BrandNavyBorderBrush}" Margin="0,2" />

                    <!-- RCON Passwort -->
                    <StackPanel Spacing="10">
                        <TextBlock Classes="section-header" FontSize="14"
                                   Text="{DynamicResource Settings.WindrosePlus.RconPassword}" />
                        <TextBlock Classes="caption" TextWrapping="Wrap"
                                   Text="{DynamicResource Settings.WindrosePlus.RconPasswordHint}" />

                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                              IsVisible="{Binding RconPassword, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBox Grid.Column="0"
                                     Text="{Binding RconPassword}"
                                     IsReadOnly="True"
                                     PasswordChar="{Binding ShowRconPassword, Converter={x:Static vm:BoolToPasswordCharConverter.Instance}}"
                                     FontFamily="Consolas,Courier New" />
                            <Button Grid.Column="1"
                                    Command="{Binding ToggleShowRconPasswordCommand}"
                                    ToolTip.Tip="{DynamicResource Settings.WindrosePlus.RconPassword}">
                                <TextBlock FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           Text="{Binding ShowRconPassword, Converter={x:Static vm:EnabledToEyeIconConverter.Instance}}" />
                            </Button>
                            <Button Grid.Column="2"
                                    Content="&#xE8C8;"
                                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                    Command="{Binding CopyRconPasswordCommand}"
                                    ToolTip.Tip="{DynamicResource Action.Copy}" />
                        </Grid>

                        <TextBlock Classes="caption"
                                   Text="{DynamicResource Settings.WindrosePlus.RconPasswordNone}"
                                   Foreground="{DynamicResource BrandTextMutedBrush}"
                                   IsVisible="{Binding RconPassword, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                    </StackPanel>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════
                 SPEICHERN
            ═══════════════════════════════════════ -->
            <Border Margin="0,20,0,0" Padding="16"
                    Background="{DynamicResource BrandNavySurfaceAltBrush}"
                    BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Classes="body" FontWeight="SemiBold"
                                   Text="{DynamicResource Settings.Save.Title}" />
                        <TextBlock Classes="caption"
                                   Text="{DynamicResource Settings.Save.Hint}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="primary"
                            Content="{DynamicResource Action.Save}"
                            Command="{Binding SaveCommand}"
                            MinWidth="120" />
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════
                 GRUPPE: APP
            ═══════════════════════════════════════ -->
            <TextBlock Classes="group-label" Text="{DynamicResource Settings.Group.App}" />

            <!-- App-Update -->
            <Border Classes="card" Margin="0,0,0,12">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Settings.AppUpdate.Title}" />
                    <TextBlock Classes="caption" TextWrapping="Wrap"
                               Text="{DynamicResource Settings.AppUpdate.Hint}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Content="{DynamicResource Settings.AppUpdate.CheckNow}"
                                Command="{Binding CheckAppUpdateCommand}"
                                IsEnabled="{Binding !IsUpdateCheckBusy}" />
                        <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IsUpdateCheckBusy}" />
                        <TextBlock Text="{Binding UpdateCheckStatus}"
                                   Classes="caption"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding HasUpdateAvailable}">
                        <Button Classes="primary"
                                Content="{DynamicResource Settings.AppUpdate.Download}"
                                Command="{Binding DownloadAppUpdateCommand}"
                                IsEnabled="{Binding PendingDownloadUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <Button Content="{DynamicResource Settings.AppUpdate.OpenReleasePage}"
                                Command="{Binding OpenReleasePageCommand}"
                                IsEnabled="{Binding PendingReleaseUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Über -->
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock Classes="section-header" Text="{DynamicResource Settings.About.Title}" />
                    <TextBlock Classes="body" Text="{Binding AppVersionDisplay}" />
                    <TextBlock Classes="caption" Text="{DynamicResource Settings.About.License}" />
                    <Button Content="{DynamicResource Settings.About.Show}"
                            Command="{Binding ShowAboutCommand}"
                            HorizontalAlignment="Left" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
