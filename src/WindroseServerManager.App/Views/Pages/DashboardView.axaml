<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel>
            <TextBlock Classes="page-title" Text="{DynamicResource Dashboard.Title}" />
            <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Subtitle}" Margin="0,4,0,20" />

            <!-- Crash Warning -->
            <Border Classes="card" Margin="0,0,0,16" IsVisible="{Binding HasRecentCrash}"
                    BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Classes="section-header" Text="{DynamicResource Dashboard.Crash.Title}" />
                        <TextBlock Classes="caption" Text="{Binding LastCrashPathDisplay}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Classes="subtle" Content="{DynamicResource Dashboard.Crash.CopyPath}" Command="{Binding CopyCrashPathCommand}" />
                        <Button Classes="subtle" Content="{DynamicResource Dashboard.Crash.OpenLog}" Command="{Binding OpenCrashLogCommand}" />
                        <Button Classes="subtle" Content="✕" Command="{Binding DismissCrashWarningCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Welcome / Onboarding Card (First Run) -->
            <Border Classes="card" Margin="0,0,0,16"
                    IsVisible="{Binding IsFirstRun}">
                <StackPanel Spacing="12">
                    <TextBlock Classes="section-header" Text="{DynamicResource Dashboard.Welcome.Title}" />
                    <TextBlock Classes="body muted"
                               Text="{DynamicResource Dashboard.Welcome.Intro}" />
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <Grid ColumnDefinitions="32,*">
                            <TextBlock Grid.Column="0" Classes="section-header" Text="1." Foreground="{DynamicResource BrandAmberBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{DynamicResource Dashboard.Welcome.Step1.Title}" />
                                <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Welcome.Step1.Desc}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="32,*">
                            <TextBlock Grid.Column="0" Classes="section-header" Text="2." Foreground="{DynamicResource BrandAmberBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{DynamicResource Dashboard.Welcome.Step2.Title}" />
                                <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Welcome.Step2.Desc}" />
                            </StackPanel>
                        </Grid>
                        <Grid ColumnDefinitions="32,*">
                            <TextBlock Grid.Column="0" Classes="section-header" Text="3." Foreground="{DynamicResource BrandAmberBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{DynamicResource Dashboard.Welcome.Step3.Title}" />
                                <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Welcome.Step3.Desc}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    <Button Classes="primary"
                            Content="{DynamicResource Dashboard.Welcome.InstallNow}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Command="{Binding GoToInstallationCommand}" />
                </StackPanel>
            </Border>

            <Border Classes="card" Margin="0,0,0,16"
                    IsVisible="{Binding InviteCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Classes="section-header"
                                   Text="{Binding ServerName}"
                                   IsVisible="{Binding HasServerName}" />
                        <TextBlock Classes="body muted"
                                   Text="{DynamicResource Dashboard.NoServerName}"
                                   IsVisible="{Binding !HasServerName}" />
                        <TextBlock Classes="caption" Text="{DynamicResource Dashboard.InviteCode}" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding InviteCode, FallbackValue='—'}"
                                   FontFamily="Consolas,Courier New"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="subtle"
                            Content="{DynamicResource Action.Copy}"
                            VerticalAlignment="Center"
                            Command="{Binding CopyInviteCodeCommand}"
                            IsEnabled="{Binding InviteCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </Grid>
            </Border>

            <Border Classes="card" Margin="0,0,0,16">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Classes="caption" Text="{DynamicResource Dashboard.ServerStatus}" />
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Ellipse Width="12" Height="12"
                                         Fill="{Binding Status, Converter={x:Static vm:ServerStatusToBrushConverter.Instance}}" />
                                <TextBlock Classes="section-header" Text="{Binding Status, Converter={x:Static vm:ServerStatusToLocalizedTextConverter.Instance}}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                            <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Uptime}" HorizontalAlignment="Right" />
                            <TextBlock Classes="section-header" Text="{Binding UptimeText}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="primary action-btn" Content="{DynamicResource Action.Start}" Command="{Binding StartCommand}" IsEnabled="{Binding !IsBusy}" />
                        <Button Classes="action-btn" Content="{DynamicResource Action.Stop}" Command="{Binding StopCommand}" IsEnabled="{Binding !IsBusy}" />
                        <Button Classes="action-btn" Content="{DynamicResource Action.Restart}" Command="{Binding RestartCommand}" IsEnabled="{Binding !IsBusy}" />
                        <Button Classes="danger action-btn" Content="{DynamicResource Action.ForceKill}" Command="{Binding KillCommand}" IsEnabled="{Binding !IsBusy}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="subtle" Content="{DynamicResource Dashboard.Start.WithBackup}"
                                Command="{Binding StartWithBackupCommand}"
                                IsEnabled="{Binding !IsBusy}" />
                        <Button Classes="subtle" Content="{DynamicResource Dashboard.OpenServerDir}"
                                Command="{Binding OpenServerDirCommand}"
                                IsEnabled="{Binding CanOpenServerDir}" />
                        <Button Classes="subtle" Content="{DynamicResource Dashboard.OpenServerDescription}"
                                Command="{Binding OpenServerDescriptionCommand}"
                                IsEnabled="{Binding CanOpenServerDescription}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="16" RowSpacing="16">

                <Border Grid.Row="0" Grid.Column="0" Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Installation}" />
                        <TextBlock Classes="section-header"
                                   Text="{Binding InstalledStatusText}" />
                        <TextBlock Classes="body muted"
                                   Text="{Binding BuildIdText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="caption" Text="{DynamicResource Dashboard.ServerProcess}" />
                        <TextBlock Classes="body" Text="{Binding ProcCpuDisplay}" />
                        <TextBlock Classes="body" Text="{Binding ProcRamDisplay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="caption" Text="{DynamicResource Dashboard.Host}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="body" Text="{Binding HostCpuDisplay}" />
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding HostCpu}" Height="6" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="body" Text="{Binding HostRamDisplay}" />
                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding HostRamPercent}" Height="6" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="4">
                            <TextBlock Classes="body muted" Text="{Binding DiskDisplay}" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding DiskUsedPercent}" Height="6" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card" Margin="0,16,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Classes="caption" Text="{DynamicResource Dashboard.ActiveWorld}" />
                        <StackPanel IsVisible="{Binding HasActiveWorld}" Spacing="2">
                            <TextBlock Classes="section-header"
                                       Text="{Binding ActiveWorldDisplayName}" />
                            <TextBlock Classes="body muted"
                                       FontFamily="Consolas,Courier New" FontSize="12"
                                       Text="{Binding ActiveWorldId}"
                                       IsVisible="{Binding ShowActiveWorldIdSubtitle}" />
                        </StackPanel>
                        <TextBlock Classes="body muted"
                                   IsVisible="{Binding !HasActiveWorld}"
                                   Text="{DynamicResource Dashboard.NoActiveWorld}" />
                    </StackPanel>
                    <Button Grid.Column="1" Classes="subtle" Content="{DynamicResource Dashboard.GoToConfiguration}"
                            VerticalAlignment="Center"
                            Command="{Binding GoToConfigurationCommand}" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
