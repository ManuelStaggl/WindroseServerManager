<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.EditorView"
             x:DataType="vm:EditorViewModel">
    <Panel>

        <!-- Opt-out empty state -->
        <StackPanel Classes="empty-state" IsVisible="{Binding !IsWindrosePlusActive}">
            <TextBlock Classes="empty-state-icon" Text="&#xE70F;" />
            <TextBlock Classes="empty-state-title"
                       Text="{DynamicResource Editor.OptOut.Title}" />
            <TextBlock Classes="empty-state-body"
                       Text="{DynamicResource Editor.OptOut.Desc}" />
            <Button Classes="primary"
                    Content="{DynamicResource WindrosePlus.OptOut.Cta}"
                    Command="{Binding InstallWindrosePlusCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0" />
        </StackPanel>

        <!-- Normal content -->
        <Grid IsVisible="{Binding IsWindrosePlusActive}"
              RowDefinitions="Auto,*,Auto" RowSpacing="16">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{DynamicResource Editor.Title}" Classes="page-title" />
                <TextBlock Text="{DynamicResource Editor.Subtitle}" Classes="caption muted" />
            </StackPanel>

            <!-- Categories -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategoryGroup">
                            <Border Classes="card" Padding="0" Margin="0,0,0,16">
                                <StackPanel>
                                    <!-- Category header -->
                                    <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                            CornerRadius="8,8,0,0" Padding="16,12">
                                        <TextBlock Text="{Binding CategoryDisplayName}"
                                                   Classes="section-header" />
                                    </Border>

                                    <!-- Entries -->
                                    <ItemsControl ItemsSource="{Binding Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConfigEntryViewModel">
                                                <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="16,14">
                                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">

                                                        <!-- Float: header row (name + desc + value badge + reset) -->
                                                        <Grid Grid.Row="0" IsVisible="{Binding IsFloat}"
                                                              ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Classes="body-emphasis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Classes="caption muted"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Description}" />
                                                            </StackPanel>
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                                    CornerRadius="6" Padding="10,4"
                                                                    VerticalAlignment="Center" MinWidth="64">
                                                                <StackPanel Orientation="Horizontal" Spacing="2"
                                                                            HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding RawValue}"
                                                                               FontFamily="Consolas,Courier New"
                                                                               FontSize="14" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource BrandAmberBrush}" />
                                                                    <TextBlock Classes="caption muted"
                                                                               Text="{DynamicResource Editor.Multiplier.Suffix}"
                                                                               VerticalAlignment="Bottom"
                                                                               Margin="1,0,0,1" />
                                                                </StackPanel>
                                                            </Border>
                                                            <Button Grid.Column="2" Classes="icon-btn"
                                                                    Content="&#xE777;"
                                                                    Command="{Binding ResetCommand}"
                                                                    ToolTip.Tip="{DynamicResource Editor.Reset.Tip}"
                                                                    VerticalAlignment="Center" />
                                                        </Grid>

                                                        <!-- Float: Slider + TextBox -->
                                                        <Grid Grid.Row="1" IsVisible="{Binding IsFloat}"
                                                              ColumnDefinitions="*,84" ColumnSpacing="10">
                                                            <Slider Grid.Column="0"
                                                                    Value="{Binding SliderValue}"
                                                                    Minimum="{Binding SliderMin}"
                                                                    Maximum="{Binding SliderMax}"
                                                                    TickFrequency="0.1"
                                                                    SmallChange="0.1"
                                                                    LargeChange="0.5"
                                                                    VerticalAlignment="Center" />
                                                            <TextBox Grid.Column="1"
                                                                     Classes="mono"
                                                                     Text="{Binding RawValue, Mode=TwoWay}"
                                                                     HorizontalContentAlignment="Center" />
                                                        </Grid>

                                                        <!-- Bool: label + toggle + reset in one row -->
                                                        <Grid Grid.Row="0" IsVisible="{Binding IsBool}"
                                                              ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Classes="body-emphasis"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock Classes="caption muted"
                                                                           TextWrapping="Wrap"
                                                                           Text="{Binding Description}" />
                                                            </StackPanel>
                                                            <ToggleSwitch Grid.Column="1"
                                                                          IsChecked="{Binding BoolValue}"
                                                                          VerticalAlignment="Center"
                                                                          OnContent="" OffContent="" />
                                                            <Button Grid.Column="2" Classes="icon-btn"
                                                                    Content="&#xE777;"
                                                                    Command="{Binding ResetCommand}"
                                                                    ToolTip.Tip="{DynamicResource Editor.Reset.Tip}"
                                                                    VerticalAlignment="Center" />
                                                        </Grid>

                                                        <!-- Text / Int / Password: label above, input below -->
                                                        <Grid Grid.Row="0" IsVisible="{Binding IsText}"
                                                              ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                            <StackPanel Grid.Column="0" Spacing="6">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Classes="body-emphasis"
                                                                               Text="{Binding DisplayName}" />
                                                                    <TextBlock Classes="caption muted"
                                                                               TextWrapping="Wrap"
                                                                               Text="{Binding Description}" />
                                                                </StackPanel>
                                                                <!-- Password: masked + eye toggle -->
                                                                <Grid IsVisible="{Binding IsPassword}"
                                                                      ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                                    <TextBox Grid.Column="0"
                                                                             IsVisible="{Binding !IsPasswordVisible}"
                                                                             Text="{Binding RawValue, Mode=TwoWay}"
                                                                             PasswordChar="•" />
                                                                    <TextBox Grid.Column="0"
                                                                             Classes="mono"
                                                                             IsVisible="{Binding IsPasswordVisible}"
                                                                             Text="{Binding RawValue, Mode=TwoWay}" />
                                                                    <Button Grid.Column="1" Classes="icon-btn"
                                                                            Command="{Binding TogglePasswordCommand}"
                                                                            ToolTip.Tip="{DynamicResource Editor.Password.ToggleTip}">
                                                                        <Panel>
                                                                            <TextBlock IsVisible="{Binding !IsPasswordVisible}"
                                                                                       Text="&#xE7B3;"
                                                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                            <TextBlock IsVisible="{Binding IsPasswordVisible}"
                                                                                       Text="&#xED1A;"
                                                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Panel>
                                                                    </Button>
                                                                </Grid>
                                                                <!-- Normal TextBox (int / string, not password) -->
                                                                <TextBox IsVisible="{Binding !IsPassword}"
                                                                         Text="{Binding RawValue, Mode=TwoWay}" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1" Classes="icon-btn"
                                                                    Content="&#xE777;"
                                                                    Command="{Binding ResetCommand}"
                                                                    ToolTip.Tip="{DynamicResource Editor.Reset.Tip}"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,22,0,0" />
                                                        </Grid>

                                                        <!-- Error message (all types) -->
                                                        <TextBlock Grid.Row="2"
                                                                   Classes="caption"
                                                                   Text="{Binding ErrorMessage}"
                                                                   Foreground="{DynamicResource BrandErrorBrush}"
                                                                   IsVisible="{Binding HasError}"
                                                                   Margin="0,2,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto">
                <Button Grid.Column="0" Classes="subtle"
                        Content="{DynamicResource Editor.ResetAll}"
                        Command="{Binding ResetAllCommand}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{DynamicResource Editor.ValidationError}"
                               Foreground="{DynamicResource BrandErrorBrush}"
                               IsVisible="{Binding HasAnyError}"
                               VerticalAlignment="Center" />
                    <Button Classes="primary"
                            Content="{DynamicResource Editor.Save}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>

        </Grid><!-- /Normal content -->

    </Panel>
</UserControl>
