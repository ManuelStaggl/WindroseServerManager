<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.EditorView"
             x:DataType="vm:EditorViewModel">
    <Panel Margin="24">

        <!-- Opt-out empty state -->
        <StackPanel IsVisible="{Binding !IsWindrosePlusActive}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                       FontSize="48" HorizontalAlignment="Center"
                       Foreground="{DynamicResource BrandTextMutedBrush}" />
            <TextBlock Text="{DynamicResource Editor.OptOut.Title}"
                       Classes="section-header" HorizontalAlignment="Center" />
            <TextBlock Text="{DynamicResource Editor.OptOut.Desc}"
                       Classes="body" HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{DynamicResource BrandTextMutedBrush}" />
            <Button Content="{DynamicResource WindrosePlus.OptOut.Cta}"
                    Command="{Binding InstallWindrosePlusCommand}"
                    HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Normal content -->
        <Grid IsVisible="{Binding IsWindrosePlusActive}"
              RowDefinitions="Auto,*,Auto" RowSpacing="16">

            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="2">
                <TextBlock Text="{DynamicResource Editor.Title}" Classes="page-title" />
                <TextBlock Text="{DynamicResource Editor.Subtitle}" Classes="caption"
                           Foreground="{DynamicResource BrandTextMutedBrush}" />
            </StackPanel>

            <!-- Categories -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategoryGroup">
                            <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="0,0,0,16">
                                <!-- Category header -->
                                <StackPanel>
                                    <Border Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                            CornerRadius="8,8,0,0" Padding="16,12">
                                        <TextBlock Text="{Binding CategoryDisplayName}"
                                                   Classes="section-header" />
                                    </Border>

                                    <!-- Entries -->
                                    <ItemsControl ItemsSource="{Binding Entries}" Margin="0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ConfigEntryViewModel">
                                                <Border BorderBrush="{DynamicResource BrandNavyBorderBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="16,14">
                                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">

                                                        <!-- Float: full-width slider row -->
                                                        <Grid Grid.Row="0" IsVisible="{Binding IsFloat}"
                                                              ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                                            <!-- Left: name + desc -->
                                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="SemiBold" FontSize="14" />
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="12" TextWrapping="Wrap"
                                                                           Foreground="{DynamicResource BrandTextMutedBrush}" />
                                                            </StackPanel>
                                                            <!-- Right: value badge -->
                                                            <Border Grid.Column="1"
                                                                    Background="{DynamicResource BrandNavySurfaceAltBrush}"
                                                                    CornerRadius="6" Padding="10,4"
                                                                    VerticalAlignment="Center" MinWidth="64">
                                                                <StackPanel Orientation="Horizontal" Spacing="2"
                                                                            HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding RawValue}"
                                                                               FontFamily="Consolas,Courier New"
                                                                               FontSize="14" FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource BrandAmberBrush}" />
                                                                    <TextBlock Text="{DynamicResource Editor.Multiplier.Suffix}"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource BrandTextMutedBrush}"
                                                                               VerticalAlignment="Bottom" Margin="1,0,0,1" />
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>

                                                        <!-- Float: Slider + TextBox -->
                                                        <Grid Grid.Row="1" IsVisible="{Binding IsFloat}"
                                                              ColumnDefinitions="*,80" ColumnSpacing="10">
                                                            <Slider Grid.Column="0"
                                                                    Value="{Binding SliderValue}"
                                                                    Minimum="{Binding SliderMin}"
                                                                    Maximum="{Binding SliderMax}"
                                                                    TickFrequency="0.1"
                                                                    SmallChange="0.1"
                                                                    LargeChange="0.5"
                                                                    VerticalAlignment="Center" />
                                                            <TextBox Grid.Column="1"
                                                                     Text="{Binding RawValue, Mode=TwoWay}"
                                                                     HorizontalContentAlignment="Center"
                                                                     FontFamily="Consolas,Courier New"
                                                                     FontSize="13" />
                                                        </Grid>

                                                        <!-- Bool: label + toggle in one row -->
                                                        <Grid Grid.Row="0" IsVisible="{Binding IsBool}"
                                                              ColumnDefinitions="*,Auto" ColumnSpacing="16">
                                                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="SemiBold" FontSize="14" />
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="12" TextWrapping="Wrap"
                                                                           Foreground="{DynamicResource BrandTextMutedBrush}" />
                                                            </StackPanel>
                                                            <ToggleSwitch Grid.Column="1"
                                                                          IsChecked="{Binding BoolValue}"
                                                                          VerticalAlignment="Center"
                                                                          OnContent="" OffContent="" />
                                                        </Grid>

                                                        <!-- Text / Int / Password: label above, input below -->
                                                        <StackPanel Grid.Row="0" IsVisible="{Binding IsText}"
                                                                    Spacing="6">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontWeight="SemiBold" FontSize="14" />
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="12" TextWrapping="Wrap"
                                                                           Foreground="{DynamicResource BrandTextMutedBrush}" />
                                                            </StackPanel>
                                                            <!-- Password TextBox -->
                                                            <TextBox IsVisible="{Binding IsPassword}"
                                                                     Text="{Binding RawValue, Mode=TwoWay}"
                                                                     PasswordChar="•"
                                                                     PlaceholderText="Leer lassen = kein Passwort" />
                                                            <!-- Normal TextBox (int / string) -->
                                                            <TextBox IsVisible="{Binding !IsPassword}"
                                                                     Text="{Binding RawValue, Mode=TwoWay}" />
                                                        </StackPanel>

                                                        <!-- Error message (all types) -->
                                                        <TextBlock Grid.Row="2"
                                                                   Text="{Binding ErrorMessage}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource BrandErrorBrush}"
                                                                   IsVisible="{Binding HasError}"
                                                                   Margin="0,2,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <TextBlock Text="{DynamicResource Editor.ValidationError}"
                           Foreground="{DynamicResource BrandErrorBrush}"
                           IsVisible="{Binding HasAnyError}"
                           VerticalAlignment="Center" />
                <Button Content="{DynamicResource Editor.Save}"
                        Command="{Binding SaveCommand}"
                        Classes="accent" />
            </StackPanel>

        </Grid><!-- /Normal content -->

    </Panel>
</UserControl>
