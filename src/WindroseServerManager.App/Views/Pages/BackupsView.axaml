<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.BackupsView"
             x:DataType="vm:BackupsViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Classes="page-title" Text="{DynamicResource Backups.Title}" />
        <TextBlock Grid.Row="1" Classes="caption" TextWrapping="Wrap"
                   Text="{DynamicResource Backups.Subtitle}"
                   Margin="0,4,0,20" />

        <Border Grid.Row="2" Classes="card" Margin="0,0,0,16">
            <StackPanel Spacing="12">
                <TextBlock Classes="section-header" Text="{DynamicResource Backups.BackupDir}" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding BackupDir}" IsReadOnly="True"
                             Watermark="{DynamicResource Backups.BackupDir.Placeholder}" />
                    <Button Grid.Column="1" Content="{DynamicResource Action.Change}" Command="{Binding PickBackupDirCommand}" Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Classes="card" Margin="0,0,0,16">
            <StackPanel Spacing="12">
                <TextBlock Classes="section-header" Text="{DynamicResource Backups.AutoBackups}" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <CheckBox Content="{DynamicResource ServerControl.Enabled}" IsChecked="{Binding AutoBackupEnabled}" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="body" Text="{DynamicResource Backups.IntervalMin}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding AutoBackupIntervalMinutes}" Minimum="5" Maximum="1440" Width="120" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="body" Text="{DynamicResource Backups.MaxKeep}" VerticalAlignment="Center" />
                        <NumericUpDown Value="{Binding MaxBackupsToKeep}" Minimum="1" Maximum="500" Width="120" />
                    </StackPanel>
                    <Button Classes="primary" Content="{DynamicResource Action.Save}" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Classes="card" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="primary" Content="{DynamicResource Backups.CreateNow}" Command="{Binding CreateCommand}" IsEnabled="{Binding !IsBusy}" />
                <Button Content="{DynamicResource Backups.Restore}" Command="{Binding RestoreCommand}" IsEnabled="{Binding Selected, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button Classes="danger" Content="{DynamicResource Action.Delete}" Command="{Binding DeleteCommand}" IsEnabled="{Binding Selected, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <Button Content="{DynamicResource Action.Refresh}" Command="{Binding RefreshCommand}" />
                <Button Classes="subtle" Content="{DynamicResource Backups.OpenBackupDir}" Command="{Binding OpenBackupDirCommand}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Classes="card">
            <Grid>
                <DataGrid ItemsSource="{Binding Backups}" SelectedItem="{Binding Selected}"
                          IsReadOnly="True" AutoGenerateColumns="False" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{DynamicResource Backups.Col.File}" Binding="{Binding FileName}" Width="*" />
                        <DataGridTextColumn Header="{DynamicResource Backups.Col.Created}" Binding="{Binding CreatedUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="180" />
                        <DataGridTextColumn Header="{DynamicResource Backups.Col.SizeMb}" Binding="{Binding SizeBytes, Converter={x:Static vm:SizeToMbConverter.Instance}}" Width="120" />
                        <DataGridTextColumn Header="{DynamicResource Backups.Col.Automatic}" Binding="{Binding IsAutomatic}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="{DynamicResource Backups.None}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource BrandTextMutedBrush}"
                           IsVisible="{Binding Backups.Count, Converter={x:Static vm:CountToInverseBoolConverter.Instance}}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
