<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Pages.PlayersView"
             x:DataType="vm:PlayersViewModel">
    <StackPanel Margin="24" Spacing="8">
        <TextBlock Text="{DynamicResource Players.Title}" Classes="page-title" />
        <TextBlock Text="{DynamicResource Players.Subtitle}" Opacity="0.7" />
    </StackPanel>
</UserControl>
