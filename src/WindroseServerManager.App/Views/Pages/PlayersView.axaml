<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             xmlns:m="using:WindroseServerManager.Core.Models"
             x:Class="WindroseServerManager.App.Views.Pages.PlayersView"
             x:DataType="vm:PlayersViewModel">
    <Panel>

        <!-- Opt-out empty state -->
        <StackPanel Classes="empty-state" IsVisible="{Binding !IsWindrosePlusActive}">
            <TextBlock Classes="empty-state-icon" Text="&#xE721;" />
            <TextBlock Classes="empty-state-title"
                       Text="{DynamicResource Players.OptOut.Title}" />
            <TextBlock Classes="empty-state-body"
                       Text="{DynamicResource Players.OptOut.Desc}" />
            <Button Classes="primary"
                    Content="{DynamicResource WindrosePlus.OptOut.Cta}"
                    Command="{Binding InstallWindrosePlusCommand}"
                    HorizontalAlignment="Center"
                    Margin="0,4,0,0" />
        </StackPanel>

        <!-- Normal content -->
        <Grid IsVisible="{Binding IsWindrosePlusActive}"
              RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="{DynamicResource Players.Title}" Classes="page-title" />
                <TextBlock Text="{DynamicResource Players.Subtitle}" Classes="caption muted" />
            </StackPanel>

            <!-- Error Banner -->
            <Border Grid.Row="1" Classes="alert-error"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <TextBlock Grid.Column="0"
                               Text="&#xEA39;"
                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                               FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandErrorBrush}" />
                    <TextBlock Grid.Column="1" Classes="body"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Player List -->
            <Border Grid.Row="2" Classes="card" Padding="0">
                <Grid>
                    <ProgressBar IsIndeterminate="True" Height="3"
                                 VerticalAlignment="Top" CornerRadius="8,8,0,0"
                                 IsVisible="{Binding IsLoading}" />

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding HasPlayers}">
                        <ItemsControl ItemsSource="{Binding Players}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="m:WindrosePlusPlayer">
                                    <Border Classes="list-row">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Alive Status Dot -->
                                            <Ellipse Grid.Column="0" Classes="status-dot"
                                                     Margin="0,0,14,0"
                                                     Fill="{Binding Alive, Converter={x:Static vm:AliveToBrushConverter.Instance}}"
                                                     ToolTip.Tip="{Binding Alive, Converter={x:Static vm:BoolToYesNoConverter.Instance}}" />

                                            <!-- Player Name -->
                                            <TextBlock Grid.Column="1"
                                                       Classes="body-emphasis"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- Row Actions -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal" Spacing="6"
                                                        VerticalAlignment="Center">
                                                <Button Classes="btn-row danger"
                                                        Content="{DynamicResource Players.Kick}"
                                                        Command="{Binding $parent[UserControl].((vm:PlayersViewModel)DataContext).KickCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Classes="btn-row danger"
                                                        Content="{DynamicResource Players.Ban}"
                                                        Command="{Binding $parent[UserControl].((vm:PlayersViewModel)DataContext).BanCommand}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel Classes="empty-state" IsVisible="{Binding HasNoPlayers}">
                        <TextBlock Classes="empty-state-icon" Text="&#xE716;" />
                        <TextBlock Classes="empty-state-title"
                                   Text="{DynamicResource Players.Empty}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Broadcast Bar -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         Text="{Binding BroadcastMessage, Mode=TwoWay}"
                         PlaceholderText="{DynamicResource Players.Broadcast.Label}" />
                <Button Grid.Column="1" Classes="primary"
                        Content="{DynamicResource Players.Broadcast.Send}"
                        Command="{Binding BroadcastCommand}" />
            </Grid>
        </Grid><!-- /Normal content -->

    </Panel>
</UserControl>
