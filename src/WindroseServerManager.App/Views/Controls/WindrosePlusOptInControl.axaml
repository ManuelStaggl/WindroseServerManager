<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WindroseServerManager.App.ViewModels"
             x:Class="WindroseServerManager.App.Views.Controls.WindrosePlusOptInControl"
             x:DataType="vm:IWindrosePlusOptInContext">
    <StackPanel Spacing="10">

        <!-- Feature grid: 3 columns × 2 rows = 6 tiles (kompakter als 2×3) -->
        <Grid RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,*,*"
              RowSpacing="6"
              ColumnSpacing="6">

            <!-- Tile: Players -->
            <Border Grid.Row="0" Grid.Column="0"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x1F465;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.Players}" />
                </StackPanel>
            </Border>

            <!-- Tile: Kick & Ban -->
            <Border Grid.Row="0" Grid.Column="1"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x1F6AB;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.KickBan}" />
                </StackPanel>
            </Border>

            <!-- Tile: Broadcast -->
            <Border Grid.Row="0" Grid.Column="2"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x1F4E2;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.Broadcast}" />
                </StackPanel>
            </Border>

            <!-- Tile: Events -->
            <Border Grid.Row="1" Grid.Column="0"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x1F4DC;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.Events}" />
                </StackPanel>
            </Border>

            <!-- Tile: Sea Chart -->
            <Border Grid.Row="1" Grid.Column="1"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x1F5FA;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.SeaChart}" />
                </StackPanel>
            </Border>

            <!-- Tile: INI-Editor -->
            <Border Grid.Row="1" Grid.Column="2"
                    Classes="feature-tile">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock FontSize="16"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrandAmberBrush}"
                               Text="&#x2699;" />
                    <TextBlock Classes="caption"
                               VerticalAlignment="Center"
                               Text="{DynamicResource Feature.IniEditor}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- GitHub link -->
        <Button Classes="subtle"
                HorizontalAlignment="Left"
                Content="{DynamicResource Feature.GitHubLink}"
                Click="OnGitHubLinkClick" />

        <!-- Disclaimer -->
        <TextBlock Classes="caption"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource BrandTextMutedBrush}"
                   Text="{DynamicResource Wizard.WindrosePlus.Disclaimer}" />

        <!-- Opt-in toggle -->
        <CheckBox x:Name="OptInCheckBox"
                  Content="{DynamicResource Wizard.WindrosePlus.OptIn}"
                  IsChecked="{Binding IsOptingIn, Mode=TwoWay}" />

        <!-- Secrets form (only visible when opting in) -->
        <StackPanel Spacing="12"
                    IsVisible="{Binding IsOptingIn}">

            <!-- RCON password row -->
            <StackPanel Spacing="6">
                <TextBlock Classes="body"
                           Text="{DynamicResource Wizard.WindrosePlus.RconLabel}"
                           ToolTip.Tip="{DynamicResource Wizard.WindrosePlus.RconTooltip}" />
                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="4">
                    <TextBox Grid.Column="0" Classes="mono"
                             x:Name="RconPasswordBox"
                             PasswordChar="•"
                             Text="{Binding RconPassword, Mode=TwoWay}" />
                    <Button Grid.Column="1" Classes="icon-btn"
                            Content="&#xE7B3;"
                            Click="OnTogglePasswordVisibility"
                            ToolTip.Tip="{DynamicResource Wizard.WindrosePlus.RconLabel}" />
                    <Button Grid.Column="2" Classes="icon-btn"
                            Content="&#xE8C8;"
                            Click="OnCopyPassword" />
                    <Button Grid.Column="3" Classes="icon-btn"
                            Content="&#xE72C;"
                            Click="OnRegeneratePassword" />
                </Grid>
            </StackPanel>

            <!-- Dashboard port row (inline label + value) -->
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Classes="body"
                               Text="{DynamicResource Wizard.WindrosePlus.PortLabel}" />
                    <TextBlock Classes="caption"
                               Foreground="{DynamicResource BrandTextMutedBrush}"
                               TextWrapping="Wrap"
                               Text="{DynamicResource Wizard.WindrosePlus.PortHint}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Classes="body"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                           Text="{Binding DashboardPort}" />
            </Grid>

            <!-- Admin Steam-ID row -->
            <StackPanel Spacing="6">
                <TextBlock Classes="body"
                           Text="{DynamicResource Wizard.WindrosePlus.SteamIdLabel}" />
                <TextBox x:Name="SteamIdBox"
                         Text="{Binding AdminSteamId, Mode=TwoWay}"
                         PlaceholderText="{DynamicResource Wizard.WindrosePlus.SteamIdPlaceholder}"
                         LostFocus="OnSteamIdLostFocus" />
                <TextBlock Classes="caption"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource BrandTextMutedBrush}"
                           IsVisible="{Binding IsSteamIdMissing}"
                           Text="{DynamicResource Wizard.WindrosePlus.SteamIdRequired}" />
                <TextBlock Classes="caption"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource BrandErrorBrush}"
                           IsVisible="{Binding HasSteamIdError}"
                           Text="{DynamicResource Error.WindrosePlus.SteamIdInvalid}" />
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
