<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource BrandNavyBrush}" />
        <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
    </Style>

    <Style Selector="TextBlock.page-title">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="TextBlock.section-header">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.body">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <!-- Body SemiBold: für Listen-Einträge, Karten-Titel, Namen -->
    <Style Selector="TextBlock.body-emphasis">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <!-- Body klein: für dichte Formulare (parameter labels, secondary meta), 13px -->
    <Style Selector="TextBlock.body-sm">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
    </Style>

    <!-- Caption klein: für Badges, Timestamps, Helper-Text, 11px -->
    <Style Selector="TextBlock.caption-sm">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource BrandTextMutedBrush}" />
    </Style>

    <!-- Monospace: für Log-Zeilen, Timestamps in Listen, Invite-Codes -->
    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="Consolas,Courier New" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.mono-sm">
        <Setter Property="FontFamily" Value="Consolas,Courier New" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
    </Style>

    <Style Selector="TextBlock.group-label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextMutedBrush}" />
        <Setter Property="Margin" Value="2,20,0,6" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Card mit Hover-Tint: für interaktive Listenelemente (Mod-Cards, Server-Cards) -->
    <Style Selector="Border.card-hover">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.card-hover:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>

    <!-- ==================== BUTTONS ==================== -->

    <!-- Action-Buttons: einheitliche Mindestbreite für Button-Gruppen (Start/Stop/…) -->
    <Style Selector="Button.action-btn">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>




    <!-- Primary: Amber filled -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandAmberHoverBrush}" />
        <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandAmberPressBrush}" />
        <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
    </Style>

    <!-- Danger -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.danger /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandErrorBrush}" />
    </Style>

    <!-- Subtle: outlined secondary button -->
    <Style Selector="Button.subtle">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.subtle /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.subtle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.subtle:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberPressBrush}" />
    </Style>

    <!-- Default Button (no class): make it look like subtle -->
    <Style Selector="Window Button:not(.primary):not(.danger):not(.subtle):not(.nav-item)">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Window Button:not(.primary):not(.danger):not(.subtle):not(.nav-item) /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Window Button:not(.primary):not(.danger):not(.subtle):not(.nav-item):pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="Window Button:not(.primary):not(.danger):not(.subtle):not(.nav-item):pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberPressBrush}" />
    </Style>

    <!-- ==================== NAV ==================== -->

    <Style Selector="RadioButton.nav-item">
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="Margin" Value="6,2" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter x:Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.nav-item:pointerover /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
    </Style>
    <Style Selector="RadioButton.nav-item:checked">
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="RadioButton.nav-item:checked /template/ Border#RootBorder">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
    </Style>

    <!-- Weekday-Pill ToggleButton: kompakte Mo/Di/Mi-Chips -->
    <Style Selector="ToggleButton.weekday-pill">
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ToggleButton.weekday-pill /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>
    <Style Selector="ToggleButton.weekday-pill:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberHoverBrush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="ToggleButton.weekday-pill:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ToggleButton.weekday-pill:checked:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandAmberHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberHoverBrush}" />
        <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
    </Style>

    <!-- Log-Line: Monospace + per-line color via Binding -->
    <Style Selector="TextBlock.log-line">
        <Setter Property="FontFamily" Value="Consolas,Courier New" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ==================== INPUTS ==================== -->

    <Style Selector="TextBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CaretBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberHoverBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="ComboBox:pointerover /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberHoverBrush}" />
    </Style>
    <Style Selector="ComboBox:focus /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="ComboBox:focus-within /template/ Border#Background">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>

    <!-- NumericUpDown -->
    <Style Selector="NumericUpDown">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="NumericUpDown:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#PART_Border">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberHoverBrush}" />
    </Style>

    <!-- RadioButton (non-nav) -->
    <Style Selector="RadioButton:not(.nav-item)">
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="RadioButton:not(.nav-item):checked /template/ Ellipse#CheckGlyph">
        <Setter Property="Fill" Value="{DynamicResource BrandAmberBrush}" />
    </Style>
    <Style Selector="RadioButton:not(.nav-item):checked /template/ Ellipse#OuterEllipse">
        <Setter Property="Stroke" Value="{DynamicResource BrandAmberBrush}" />
    </Style>

    <!-- ==================== SCROLLBAR ==================== -->

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="8" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource BrandTextMutedBrush}" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ==================== DATAGRID ==================== -->

    <Style Selector="DataGrid">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HeadersVisibility" Value="Column" />
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="Opacity" Value="0.6" />
    </Style>
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{DynamicResource BrandAmberSubtleBrush}" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <!-- ==================== PAGE ROOT ==================== -->

    <!-- Einheitliches Outer-Padding aller Pages: auf den Panel/Grid/ScrollViewer anwenden,
         der direkter Content-Root der View ist. Shell fügt bereits 24/12/24/24 ContentControl-Margin hinzu,
         daher ist das interne Page-Padding bewusst "0" — Pages steuern Innenabstand über Sections. -->
    <Style Selector="UserControl">
        <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>

    <!-- ==================== BADGES ==================== -->

    <!-- Neutral-Badge: für Metadaten (Zeitstempel-Pill, Nexus-Status, Backup-Tag) -->
    <Style Selector="Border.badge">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
    </Style>

    <!-- Akzent-Badge: gefülltes Amber (aktiver Server, Primary-Tag) -->
    <Style Selector="Border.badge-accent">
        <Setter Property="Background" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge-accent > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <!-- Status-Badges: subtiler Hintergrund + kräftige Schrift -->
    <Style Selector="Border.badge-success">
        <Setter Property="Background" Value="{DynamicResource BrandSuccessSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandSuccessBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge-success > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandSuccessBrush}" />
    </Style>

    <Style Selector="Border.badge-error">
        <Setter Property="Background" Value="{DynamicResource BrandErrorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge-error > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandErrorBrush}" />
    </Style>

    <Style Selector="Border.badge-warning">
        <Setter Property="Background" Value="{DynamicResource BrandWarningSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandWarningBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.badge-warning > TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandWarningBrush}" />
    </Style>

    <!-- ==================== ICON BUTTONS ==================== -->

    <!-- Standard Icon-Button: quadratisch 32x32, nur Icon, kein Text -->
    <Style Selector="Button.icon-btn">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="MinWidth" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.icon-btn /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button.icon-btn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberPressBrush}" />
    </Style>

    <!-- Icon-Button danger Variante: Hover/Press wird rot (für Löschen, Kick, Ban) -->
    <Style Selector="Button.icon-btn.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandErrorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource BrandErrorBrush}" />
    </Style>

    <!-- Icon-Button naked: ohne Border, rein transparent (für Karten-interne Toolbar-Buttons) -->
    <Style Selector="Button.icon-btn.naked">
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.icon-btn.naked /template/ ContentPresenter">
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ==================== ROW ACTION BUTTON ==================== -->

    <!-- Kompakter Outlined-Button für Listen-Actions (Kick/Ban, Row-Actions). -->
    <Style Selector="Button.btn-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Button.btn-row /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="Button.btn-row:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandAmberBrush}" />
    </Style>

    <!-- Row-Action danger Variante: Border leicht rot, Text rot; Hover füllt mit Error-Farbe -->
    <Style Selector="Button.btn-row.danger">
        <Setter Property="Foreground" Value="{DynamicResource BrandErrorBrush}" />
    </Style>
    <Style Selector="Button.btn-row.danger /template/ ContentPresenter">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandErrorBrush}" />
    </Style>
    <Style Selector="Button.btn-row.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="TextBlock.Foreground" Value="#FFFFFF" />
    </Style>

    <!-- ==================== LIST ROW (hover-tint) ==================== -->

    <!-- Listen-Zeilen mit subtilem Hover-Tint (Players, Events). Verwendung: <Border Classes="list-row"> -->
    <Style Selector="Border.list-row">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.12" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Border.list-row:pointerover">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
    </Style>

    <!-- ==================== FEATURE TILE ==================== -->

    <!-- Kleine Info-Kachel (Feature-Übersicht in Wizards, Onboarding). Verwendung: <Border Classes="feature-tile"> -->
    <Style Selector="Border.feature-tile">
        <Setter Property="Background" Value="{DynamicResource BrandNavySurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- ==================== ALERT BANNERS ==================== -->

    <!-- Base-Alert: 3px Akzent-Streifen links + subtiler Füll-Hintergrund + Text-Icon davor.
         Verwendung: Border mit Class + Grid innen (ColumnDefinitions="Auto,*,Auto") für Icon/Text/Action -->
    <Style Selector="Border.alert">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1,1,1,1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>
    <Style Selector="Border.alert-info">
        <Setter Property="Background" Value="{DynamicResource BrandInfoSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandInfoBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>
    <Style Selector="Border.alert-success">
        <Setter Property="Background" Value="{DynamicResource BrandSuccessSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandSuccessBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>
    <Style Selector="Border.alert-warning">
        <Setter Property="Background" Value="{DynamicResource BrandWarningSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandWarningBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>
    <Style Selector="Border.alert-error">
        <Setter Property="Background" Value="{DynamicResource BrandErrorSubtleBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandErrorBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <!-- ==================== EMPTY STATE ==================== -->

    <!-- Container für Empty-States: zentriert, großzügig. Innen: Icon (TextBlock.empty-state-icon) +
         Titel (TextBlock.empty-state-title) + Body (TextBlock.empty-state-body) + optionaler Action-Button -->
    <Style Selector="StackPanel.empty-state">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Margin" Value="0,48,0,48" />
    </Style>
    <Style Selector="TextBlock.empty-state-icon">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextMutedBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.empty-state-title">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.empty-state-body">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="420" />
    </Style>

    <!-- ==================== DIVIDER ==================== -->

    <!-- Horizontaler 1px-Trenner: Verwendung <Border Classes="divider" /> statt Rectangle -->
    <Style Selector="Border.divider">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource BrandNavyBorderBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- ==================== STATUS DOT ==================== -->

    <!-- Kleiner farbiger Kreis (Firewall-Status, Online-Indicator). Verwendung: <Ellipse Classes="status-dot status-success" /> -->
    <Style Selector="Ellipse.status-dot">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Ellipse.status-dot.status-success">
        <Setter Property="Fill" Value="{DynamicResource BrandSuccessBrush}" />
    </Style>
    <Style Selector="Ellipse.status-dot.status-warning">
        <Setter Property="Fill" Value="{DynamicResource BrandWarningBrush}" />
    </Style>
    <Style Selector="Ellipse.status-dot.status-error">
        <Setter Property="Fill" Value="{DynamicResource BrandErrorBrush}" />
    </Style>
    <Style Selector="Ellipse.status-dot.status-muted">
        <Setter Property="Fill" Value="{DynamicResource BrandTextMutedBrush}" />
    </Style>

</Styles>
